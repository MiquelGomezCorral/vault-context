{
  "$schema": "./vault-context.schema.json",
  "_doc": "All defaults. Env vars override. Edit this file to customize. Restart opencode after changes.",

  "vault": {
    "path": "",
    "_doc": "Path to Obsidian vault. Default: $HOME/Desktop/Obsidian. Set OBSIDIAN_VAULT env var to override."
  },
  "mode": {
    "value": "auto",
    "_doc": "auto | off | force. Set VAULT_CONTEXT_MODE env var to override."
  },
  "search": {
    "maxHits": 3,
    "maxChars": 1800,
    "minScore": 5,
    "rgTimeoutMs": 600,
    "nativeTimeoutMs": 2000,
    "fuzzyDistance": 3,
    "allowDirs": ["CODE", "VIDEXT", "UNI"],
    "denyGlobs": [
      "!.obsidian/**",
      "!.git/**",
      "!Images/**",
      "!Excalidraw/**",
      "!**/*.canvas",
      "!**/*.excalidraw.md"
    ],
    "denyDirNames": [".obsidian", ".git", "Images", "Excalidraw"]
  },
  "cache": {
    "ttlMs": 300000,
    "maxEntries": 50
  },
  "debug": {
    "enabled": false
  },
  "keywords": {
