  "prompt": {
    "optOut": [
      "no vault", "sin obsidian", "no obsidian", "no rag",
      "no extra context", "without vault context", "skip vault", "skip obsidian"
    ],
    "force": [
      "use vault", "search obsidian", "with obsidian context",
      "usa obsidian", "busca en obsidian", "vault context", "obsidian context"
    ],
    "_doc": "optOut: phrases that skip context injection. force: phrases that force it."
  },
  "stopwords": {
    "languages": ["en", "es"],
    "_doc": "Which stopword files to load from stopwords/ directory (en.json, es.json)."
  }
